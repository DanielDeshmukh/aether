# AETHER Environment Variables
# Copy this file to .env and fill in your values

# Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/aether

# JWT Secret (Required) - Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AETHER_JWT_SECRET=your_generated_secret_here

# Frontend URL (Required - for CORS)
FRONTEND_URL=http://localhost:8080

# Environment
ENVIRONMENT=development

# AI Analysis (Optional - for Gemini-powered remediation)
GEMINI_API_KEY=your_google_ai_key

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# SMTP - Email Delivery (Optional - for magic links and report delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=AETHER <noreply@yourdomain.com>

# Server Configuration
PORT=8000
WEB_CONCURRENCY=2

# Public API URL (Optional - for screenshot URLs in PRs)
AETHER_PUBLIC_API_URL=

# Frontend Build
VITE_API_URL=
