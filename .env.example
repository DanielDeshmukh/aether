# AETHER Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# DATABASE (Required)
# Fly.io: fly postgres create → fly secrets set DATABASE_URL=...
# Local: postgresql://user:password@localhost:5432/aether
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/aether

# ============================================================
# JWT Secret (Required)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================
AETHER_JWT_SECRET=your_generated_secret_here

# ============================================================
# CORS Configuration (Required)
# Netlify: https://your-app.netlify.app
# Fly.io: Auto-set if using same domain, otherwise set Netlify URL
# Comma-separated for multiple origins
# ============================================================
FRONTEND_URL=http://localhost:8080

# ============================================================
# Environment
# Railway: Set to "production"
# Local: "development"
# ============================================================
ENVIRONMENT=development

# ============================================================
# AI Analysis (Optional - for Gemini-powered remediation)
# ============================================================
GEMINI_API_KEY=your_google_ai_key

# ============================================================
# Google OAuth (Optional)
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ============================================================
# GitHub OAuth (Optional)
# ============================================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ============================================================
# NVIDIA Orchestrator (Optional - enables Playwright-based validation)
# Set to "true" to enable the 10 OWASP attack lanes
# ============================================================
AETHER_USE_NVIDIA_ORCHESTRATOR=false
NVIDIA_API_KEY=

# ============================================================
# Allowed Validation Hosts (Optional)
# Comma-separated list of hosts allowed for active scanning
# Default: localhost,127.0.0.1,::1
# ============================================================
AETHER_VALIDATION_HOSTS=localhost,127.0.0.1,::1

# ============================================================
# SMTP - Email Delivery (Optional - for magic links and report delivery)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=AETHER <noreply@yourdomain.com>

# ============================================================
# Server Configuration
# Railway: PORT is auto-set
# ============================================================
PORT=8000
WEB_CONCURRENCY=2
REQUEST_TIMEOUT=30

# ============================================================
# Public API URL (Optional - for screenshot URLs in PRs)
# Set to your Railway backend URL for production
# ============================================================
AETHER_PUBLIC_API_URL=

# ============================================================
# Frontend Build (Netlify)
# Set to your Railway backend URL in Netlify env vars
# ============================================================
VITE_API_URL=

# ============================================================
# Quota Configuration (Optional)
# Free tier scan limit per user
# ============================================================
QUOTA_FREE_LIMIT=3

# ============================================================
# Deployment Instructions
# ============================================================
# 
# FLY.IO (Backend):
# 1. Install flyctl: https://fly.io/docs/hands-on/install-flyctl/
# 2. fly auth login
# 3. fly postgres create → note the connection string
# 4. fly secrets set DATABASE_URL="postgresql://..." AETHER_JWT_SECRET="..." FRONTEND_URL="https://your-app.netlify.app" ENVIRONMENT=production
# 5. fly launch (uses fly.toml at repo root)
# 6. fly deploy
# 7. Alembic migrations run via release_command on deploy
#
# NETLIFY (Frontend):
# 1. Connect your GitHub repo to Netlify
# 2. Set build directory to "frontend" or use netlify.toml base config
# 3. Set environment variables in Netlify dashboard:
#    - VITE_API_URL (your Fly.io backend URL)
# 4. Netlify will use frontend/netlify.toml for build config
# 5. SPA routing and security headers are pre-configured
#
# LOCAL DEVELOPMENT:
# 1. Copy .env.example to .env and fill in values
# 2. Run: docker-compose up -d (starts PostgreSQL)
# 3. Run: cd backend && pip install -r requirements.txt
# 4. Run: cd backend && alembic upgrade head
# 5. Run: npm run dev (starts both backend and frontend)
