# AETHER Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# DATABASE (Required)
# Local: postgresql://user:password@localhost:5432/aether
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/aether

# ============================================================
# JWT Secret (Required)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================
AETHER_JWT_SECRET=your_generated_secret_here

# ============================================================
# CORS Configuration
# Set to your Next.js app URL
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# Environment
# "development" or "production"
# ============================================================
ENVIRONMENT=development

# ============================================================
# NVIDIA NIM AI (Required for scan planning, verdicts, remediation)
# Get your key at: https://build.nvidia.com/settings/api-keys
# ============================================================
NVIDIA_API_KEY=your_nvidia_nim_api_key

# ============================================================
# NVIDIA Orchestrator (Optional - enables Playwright-based validation)
# Set to "true" to enable the 10 OWASP attack lanes
# ============================================================
AETHER_USE_NVIDIA_ORCHESTRATOR=false

# ============================================================
# Allowed Validation Hosts (Optional)
# Comma-separated list of hosts allowed for active scanning
# ============================================================
AETHER_VALIDATION_HOSTS=localhost,127.0.0.1,::1

# ============================================================
# SMTP - Email Delivery (Optional - for magic links and reports)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=AETHER <noreply@yourdomain.com>
RESEND_API_KEY=your_resend_api_key

# ============================================================
# Quota Configuration
# ============================================================
QUOTA_FREE_LIMIT=3

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
REQUEST_TIMEOUT=30
